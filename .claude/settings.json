{
  "permissions": {
    "allow": [
      "Bash(./scripts/doctor.sh)",
      "Bash(./scripts/doctor.sh:*)",
      "Bash(./scripts/sync-check.sh)",
      "Bash(./scripts/sync-check.sh:*)",
      "Bash(./scripts/install.sh --help)",
      "Bash(./scripts/install.sh --version:*)",
      "Bash(./scripts/c1-probe.sh:*)",
      "Bash(./scripts/c3-static-checks.sh:*)",
      "Bash(./scripts/c5-capture.sh:*)",
      "Bash(./scripts/c5-engine-select.sh:*)",
      "Bash(./scripts/c6-asset-completeness.sh:*)",
      "Bash(./scripts/c7-no-system-chrome.sh:*)",
      "Bash(./scripts/colorset-codegen.sh:*)",
      "Bash(bash -n scripts/*.sh)",
      "Bash(bash -n ./scripts/*.sh)",
      "Bash(bash -n scripts/hooks/*.sh)",
      "Bash(chmod +x scripts/*.sh)",
      "Bash(chmod +x scripts/hooks/*.sh)",
      "Bash(chmod +x scripts/hooks/*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote -v)",
      "Bash(git remote:*)",
      "Bash(wc -l:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find . -name:*)",
      "Bash(find . -type:*)",
      "Bash(find . -maxdepth:*)",
      "Bash(ls:*)",
      "Bash(cat scripts/*.sh)",
      "Bash(head:*)",
      "Bash(tail:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Grep|Glob|Regex",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/vexp-guard.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
